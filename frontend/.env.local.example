# Copy to `.env.local` and adjust. Restart `npm run dev` after changes.

# Optional: override where Next.js proxies /api/* (server-side only).
# Use when `next dev` cannot reach the API at 127.0.0.1 (e.g. WSL → API on Windows host):
#   API_PROXY_TARGET=http://172.x.x.x:8000
#   (IP from WSL: grep nameserver /etc/resolv.conf)
# Start FastAPI with: uvicorn main:app --reload --host 0.0.0.0 --port 8000

# API_PROXY_TARGET=

# Or set this instead of API_PROXY_TARGET (also used if you bypass /api rewrites in the client).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Opt-in: use Windows host IP from /etc/resolv.conf (WSL2) when proxying to port 8000
# WSL_USE_WINDOWS_HOST=1
