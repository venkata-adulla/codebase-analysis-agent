# Copy to `.env` in the repo root before `docker compose up`.
# Compose reads this file for `${VAR}` substitution. Backend and frontend also use `env_file: .env`.
#
# Postgres and Neo4j services intentionally do NOT use `env_file` — only explicit `environment:`
# entries are set — so unrelated keys (e.g. POSTGRES_PASSWORD) are not passed into Neo4j, which
# would break Neo4j 5 strict config validation.

# --- PostgreSQL (postgres container + backend) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=codebase_analysis

# --- Neo4j (compose sets NEO4J_AUTH=neo4j/${NEO4J_PASSWORD}; backend uses NEO4J_PASSWORD) ---
NEO4J_PASSWORD=

# --- Backend ---
API_KEY=
SECRET_KEY=

# --- Frontend image build args (`docker compose build` reads from this file) ---
NEXT_PUBLIC_API_KEY=

# Do NOT set NEXT_PUBLIC_API_URL=http://backend:8000 (or any Docker-only hostname). The browser
# runs outside Docker and cannot resolve `backend`. Leave unset so the UI uses same-origin `/api`
# and Next.js proxies to the API. Only set NEXT_PUBLIC_API_URL to a **public** API URL if you
# intentionally bypass rewrites and have CORS configured on the API.
# NEXT_PUBLIC_API_URL=

# If you change passwords after data volumes exist, reset volumes (`docker compose down -v`) or migrate DBs.

# --- Optional: FastAPI uses POSTGRES_*; this line is for external tooling only ---
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres:5432/codebase_analysis

# Required for codebase chat + LLM features inside the **backend** container:
# OPENAI_API_KEY=
#
# Merged PR sampling on the Temporal page (optional):
# GITHUB_TOKEN=
